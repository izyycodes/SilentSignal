Options -Indexes

# Enable URL rewriting
RewriteEngine On

# Handle Authorization Header (needed for some API calls)
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Redirect all requests to index.php except for existing files/dirs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# PHP settings for HelioHost compatibility
<IfModule mod_php.c>
    php_flag display_errors Off
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 60
    php_value memory_limit 128M
</IfModule>

# Protect sensitive directories and files
<FilesMatch "\.(sql|log|env|json|lock|md)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Allow composer.json/lock to be denied
<Files "composer.json">
    Order Allow,Deny
    Deny from all
</Files>
<Files "composer.lock">
    Order Allow,Deny
    Deny from all
</Files>

# Protect config and database dirs
<IfModule mod_rewrite.c>
    RewriteRule ^config/ - [F,L]
    RewriteRule ^database/ - [F,L]
    RewriteRule ^logs/ - [F,L]
    RewriteRule ^vendor/ - [F,L]
    RewriteRule ^models/ - [F,L]
    RewriteRule ^controllers/ - [F,L]
</IfModule>

# Set charset
AddDefaultCharset UTF-8

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
